# ── LLM ───────────────────────────────────────────────────────
# Arquivo finetunado no kaggle:
FINETUNED_MODEL_PATH=./outputs/llama-medical

# TOKEN
HUGGINGFACEHUB_API_TOKEN= # <- o token que eu mandei no zap colar aqui

# PRa maquina com gpu fraca (tipo a minha rsrs) usar o ollama para gerar resposta mais rapida:
USE_OLLAMA_FALLBACK=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
# ── Dataset MedQuAD ───────────────────────────────────────────
MEDQUAD_DIR=./data/raw/medquad

# ── Diretórios ────────────────────────────────────────────────
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_ANONYMIZED_DIR=./data/anonymized
LOG_DIR=./logs
VECTOR_STORE_PATH=./data/vectorstore

# ── Segurança ─────────────────────────────────────────────────
ENABLE_GUARDRAILS=true
AUDIT_LOG_LEVEL=INFO
