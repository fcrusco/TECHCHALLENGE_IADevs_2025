# Bytecode Python
__pycache__/
*.pyc

# Configuração local com segredos (chaves de API etc.) — copie de .env.example
.env

# Saída do fine-tuning STRIDE (texto) — o .gguf final (~3.3 GB) e os
# intermediários (lora/merged) são grandes demais para o Git. O Modelfile
# (config do Ollama) fica versionado; o resto se baixa/gera manualmente —
# ver training/output/download_dataset.txt.
training/output/*
!training/output/Modelfile
!training/output/download_dataset.txt
