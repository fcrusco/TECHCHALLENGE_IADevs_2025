# =============================================================
# LLM Provider — escolha um: openai | ollama | lmstudio
# =============================================================
LLM_PROVIDER=lmstudio

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4o

# ─── Ollama (local) ──────────────────────────────────────────
# Inicie antes de usar: ollama serve
# Use um modelo com suporte a visão — confira o que já tem baixado com: ollama list
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ─── LM Studio (local, OpenAI-compatible) ────────────────────
# Ative o servidor local no LM Studio antes de usar
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=google/gemma-4-12b-qat
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e4b
LM_STUDIO_MAX_TOKENS=1024

# =============================================================
# Backend (usado pelo app alternativo em backend/ — ver README)
# =============================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Chave de sessão do Flask (app principal, main.py) — opcional, tem um padrão
# FLASK_SECRET=troque-por-uma-chave-secreta
