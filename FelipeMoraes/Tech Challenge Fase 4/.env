# ----------------------------------------------------------------
# ROBOFLOW — chave de API (gratuita em https://roboflow.com)
# ----------------------------------------------------------------
ROBOFLOW_API_KEY=

# ----------------------------------------------------------------
# TREINAMENTO — parâmetros globais (fallback para todos os modelos)
# ----------------------------------------------------------------
TRAIN_EPOCHS=100
TRAIN_IMGSZ=640
TRAIN_BATCH=8
TRAIN_PATIENCE=20
TRAIN_DEVICE=0
TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# TREINAMENTO — INSTRUMENTOS
# ----------------------------------------------------------------
INST_TRAIN_EPOCHS=60
INST_TRAIN_IMGSZ=800
INST_TRAIN_BATCH=8
INST_TRAIN_PATIENCE=20
INST_TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# TREINAMENTO — ÁREAS CRÍTICAS
# ----------------------------------------------------------------
AREAS_TRAIN_EPOCHS=60
AREAS_TRAIN_IMGSZ=640
AREAS_TRAIN_BATCH=8
AREAS_TRAIN_PATIENCE=30
AREAS_TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# TREINAMENTO — SANGRAMENTO
# ----------------------------------------------------------------
BLEED_TRAIN_EPOCHS=100
BLEED_TRAIN_IMGSZ=640
BLEED_TRAIN_BATCH=16
BLEED_TRAIN_PATIENCE=15
BLEED_TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# TREINAMENTO — AUTOMUTILAÇÃO
# ----------------------------------------------------------------
HARM_TRAIN_EPOCHS=50
HARM_TRAIN_IMGSZ=640
HARM_TRAIN_BATCH=8
HARM_TRAIN_PATIENCE=20
HARM_TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# DETECÇÃO — parâmetros gerais de inferência
# ----------------------------------------------------------------
DETECT_CONFIDENCE=0.55
DETECT_IOU=0.45
DETECT_WINDOW=10

# ----------------------------------------------------------------
# FILTROS GEOMÉTRICOS — pós-processamento de bounding boxes
# ----------------------------------------------------------------
FILTER_MIN_BOX_AREA=0.002
FILTER_MAX_BOX_AREA=0.50
FILTER_MIN_ASPECT=1.5
FILTER_EDGE_MARGIN=0.008
FILTER_OVERLAY_TOP=0.22
FILTER_OVERLAY_BOTTOM=0.80

# ----------------------------------------------------------------
# ANOMALIAS — limiares gerais
# ----------------------------------------------------------------
ANOMALY_ABSENCE_WARN=10
ANOMALY_ABSENCE_CRITICAL=30
ANOMALY_EXCESS=5
ANOMALY_VARIATION=3

# ----------------------------------------------------------------
# INSTRUMENTOS — inferência
# ----------------------------------------------------------------
INST_CONFIDENCE=0.55
INST_MIN_ASPECT=1.0

# ----------------------------------------------------------------
# ÁREAS CRÍTICAS — inferência
# ----------------------------------------------------------------
AREAS_CONFIDENCE=0.50
AREAS_MIN_ASPECT=1.0
AREAS_MAX_BOX_AREA=0.65
AREAS_EXCESS=2

# ----------------------------------------------------------------
# SANGRAMENTO — inferência
# ----------------------------------------------------------------
BLEED_CONFIDENCE=0.45
BLEED_MIN_ASPECT=1.0
BLEED_MAX_BOX_AREA=0.80
BLEED_WARN_FRAMES=5
BLEED_CRITICAL_FRAMES=15

# ----------------------------------------------------------------
# AUTOMUTILAÇÃO — inferência
# ----------------------------------------------------------------
HARM_CONFIDENCE=0.40
HARM_MIN_ASPECT=1.0
HARM_MAX_BOX_AREA=0.75
HARM_WARN_FRAMES=3
HARM_CRITICAL_FRAMES=8
