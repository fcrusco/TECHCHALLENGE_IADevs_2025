# ----------------------------------------------------------------
# TREINAMENTO — parâmetros do YOLOv8
# ----------------------------------------------------------------
TRAIN_EPOCHS=50
TRAIN_IMGSZ=800
TRAIN_BATCH=8
TRAIN_PATIENCE=20
TRAIN_DEVICE=0
TRAIN_BASE_MODEL=yolov8m.pt

# ----------------------------------------------------------------
# AUGMENTAÇÕES — aplicadas durante o treinamento
# ----------------------------------------------------------------
AUGMENT_MOSAIC=1.0
AUGMENT_FLIPUD=0.3
AUGMENT_FLIPLR=0.5
AUGMENT_DEGREES=10.0
AUGMENT_TRANSLATE=0.1
AUGMENT_SCALE=0.5
AUGMENT_HSV_H=0.015
AUGMENT_HSV_S=0.7
AUGMENT_HSV_V=0.4

# ----------------------------------------------------------------
# DETECÇÃO — parâmetros gerais de inferência
# ----------------------------------------------------------------
DETECT_CONFIDENCE=0.55
DETECT_IOU=0.45
DETECT_WINDOW=10

# ----------------------------------------------------------------
# FILTROS GEOMÉTRICOS — pós-processamento de bounding boxes
# ----------------------------------------------------------------
FILTER_MIN_BOX_AREA=0.002
FILTER_MAX_BOX_AREA=0.50
FILTER_MIN_ASPECT=1.5
FILTER_EDGE_MARGIN=0.008
FILTER_OVERLAY_TOP=0.22
FILTER_OVERLAY_BOTTOM=0.80

# ----------------------------------------------------------------
# ANOMALIAS — limiares gerais
# ----------------------------------------------------------------
ANOMALY_ABSENCE_WARN=10
ANOMALY_ABSENCE_CRITICAL=30
ANOMALY_EXCESS=5
ANOMALY_VARIATION=3

# ----------------------------------------------------------------
# INSTRUMENTOS
# ----------------------------------------------------------------
INST_CONFIDENCE=0.55
INST_MIN_ASPECT=1.5

# ----------------------------------------------------------------
# ÁREAS CRÍTICAS
# ----------------------------------------------------------------
AREAS_CONFIDENCE=0.50
AREAS_MIN_ASPECT=1.0
AREAS_MAX_BOX_AREA=0.65
AREAS_EXCESS=2

# ----------------------------------------------------------------
# SANGRAMENTO
# ----------------------------------------------------------------
BLEED_CONFIDENCE=0.45
BLEED_MIN_ASPECT=1.0
BLEED_MAX_BOX_AREA=0.80
BLEED_WARN_FRAMES=5
BLEED_CRITICAL_FRAMES=15

# ----------------------------------------------------------------
# AUTOMUTILAÇÃO
# ----------------------------------------------------------------
HARM_CONFIDENCE=0.40
HARM_MIN_ASPECT=1.0
HARM_MAX_BOX_AREA=0.75
HARM_WARN_FRAMES=3
HARM_CRITICAL_FRAMES=8
